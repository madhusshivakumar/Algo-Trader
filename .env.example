# ── Alpaca API Keys ──────────────────────────────────
# Get yours at https://alpaca.markets (start with Paper Trading keys)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Set to "paper" for testing, "live" when ready
TRADING_MODE=paper

# ── Symbols ─────────────────────────────────────────
# Crypto symbols (trade 24/7)
CRYPTO_SYMBOLS=BTC/USD,ETH/USD

# Equity symbols (trade during US market hours only)
EQUITY_SYMBOLS=TSLA,NVDA,AMD,AAPL,META,SPY

# ── Risk Settings ───────────────────────────────────
MAX_POSITION_PCT=0.50
STOP_LOSS_PCT=0.025
DAILY_DRAWDOWN_LIMIT=0.10

# ── v2 AI Upgrades (all disabled by default) ────────
# Sentiment Analysis (FinBERT + Alpaca News API)
SENTIMENT_ENABLED=false
SENTIMENT_WEIGHT=0.15

# LLM Multi-Agent Analyst (Claude API)
LLM_ANALYST_ENABLED=false
LLM_CONVICTION_WEIGHT=0.2
LLM_QUICK_MODEL=claude-haiku-4-5-20251001
LLM_DEEP_MODEL=claude-sonnet-4-20250514
LLM_BUDGET_DAILY=1.00
LLM_ANALYST_V2_ENABLED=false
ANTHROPIC_API_KEY=

# RL Strategy Selector (DQN)
RL_STRATEGY_ENABLED=false
RL_MODEL_PATH=data/rl_models/dqn_latest.zip
RL_MIN_SHARPE_THRESHOLD=0.5

# ── v3 Production Hardening (all disabled by default) ──

# Sprint 1: Order Management & State Persistence
ORDER_MANAGEMENT_ENABLED=false
STATE_PERSISTENCE_ENABLED=false
ORDER_STALE_TIMEOUT_SECONDS=300

# Sprint 2: Risk Management Upgrades
ATR_STOPS_ENABLED=false
ATR_STOP_MULTIPLIER=2.0
VOLATILITY_SIZING_ENABLED=false
CORRELATION_CHECK_ENABLED=false
CORRELATION_THRESHOLD=0.7
SENTIMENT_FRESHNESS_CHECK=false
SENTIMENT_MAX_AGE_HOURS=24.0

# Sprint 3: Execution & Performance
PARALLEL_FETCH_ENABLED=false
FETCH_WORKERS=5
DB_ROTATION_ENABLED=false
DB_ROTATION_MAX_ROWS=100000
DB_ROTATION_KEEP_DAYS=90

# Sprint 4: Backtesting & Monitoring
HOT_RELOAD_ENABLED=false
DRIFT_DETECTION_ENABLED=false
DRIFT_LOOKBACK_DAYS=7
DRIFT_MIN_TRADES=10
